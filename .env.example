# Database
DATABASE_URL=postgres://user:password@localhost:5432/lidm

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM (OpenAI-compatible endpoint) — optional, needed for AI features
AI_LLM_API_KEY=
AI_LLM_BASE_URL=
AI_LLM_MODEL=

# S3 / Object Storage — untuk upload file (foto, dokumen, model ML)
S3_ENDPOINT=https://your-s3-endpoint.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_DEFAULT_REGION=us-east-1
S3_BUCKET=lsar

# CORS — frontend URL for production (localhost allowed by default in dev)
CORS_ORIGIN=https://your-frontend-domain.com

# ML / Analytics
CLUSTERING_ENABLED=false
MODEL_PATH=./models
CLUSTER_RETRAIN_INTERVAL=21600000

# Backend
PORT=3001

# Frontend (used at build time)
NEXT_PUBLIC_API_URL=https://lidm-api.asepharyana.my.id/api
